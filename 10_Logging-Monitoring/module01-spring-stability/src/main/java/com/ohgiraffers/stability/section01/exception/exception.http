### Section 01: 예외 처리 시스템 구축 - API 테스트
###############################################################################
# 테스트 시나리오 요약:
#
# 정상 케이스:
# - 도서 등록, 조회, 수정, 삭제
# - 재고 증가/감소
# - 다양한 검색 방법
#
# 예외 케이스:
# - BookNotFoundException (404): 존재하지 않는 도서 접근
# - DuplicateIsbnException (409): 중복 ISBN 등록
# - InsufficientStockException (400): 재고 부족
# - IllegalArgumentException (400): 잘못된 인수
# - 잘못된 요청 형식 (400): JSON 파싱 오류, 필수 필드 누락
#
# 각 예외는 GlobalExceptionHandler에서 일관된 형태로 처리되어
# 적절한 HTTP 상태 코드와 오류 정보를 반환한다.
###############################################################################

###############################################################################
# 1. 도서 등록 테스트 (정상 케이스)
###############################################################################

### 1-1. 첫 번째 도서 등록 (정상)
POST http://localhost:8080/api/v1/books
Content-Type: application/json

{
  "isbn": "9788966262281",
  "title": "스프링 부트와 AWS로 혼자 구현하는 웹 서비스",
  "author": "이동욱",
  "publisher": "프리렉",
  "publishDate": "2019-12-24",
  "stockQuantity": 10
}

### 1-2. 두 번째 도서 등록 (정상)
POST http://localhost:8080/api/v1/books
Content-Type: application/json

{
  "isbn": "9791162243685",
  "title": "Clean Code 클린 코드",
  "author": "로버트 C. 마틴",
  "publisher": "인사이트",
  "publishDate": "2013-12-24",
  "stockQuantity": 5
}

### 1-3. 세 번째 도서 등록 (정상)
POST http://localhost:8080/api/v1/books
Content-Type: application/json

{
  "isbn": "9788960773417",
  "title": "Effective Java 3/E",
  "author": "조슈아 블로크",
  "publisher": "인사이트",
  "publishDate": "2018-11-01",
  "stockQuantity": 3
}

###############################################################################
# 2. 도서 조회 테스트 (정상 케이스)
###############################################################################

### 2-1. 전체 도서 목록 조회 (정상)
GET http://localhost:8080/api/v1/books

### 2-2. 도서 ID로 조회 (정상) - 위에서 등록한 도서 중 ID=1인 도서 조회
GET http://localhost:8080/api/v1/books/1

### 2-3. ISBN으로 조회 (정상)
GET http://localhost:8080/api/v1/books/isbn/9788966262281

### 2-4. 제목으로 검색 (정상)
GET http://localhost:8080/api/v1/books/search?keyword=스프링

###############################################################################
# 3. 재고 관리 테스트 (정상 케이스)
###############################################################################

### 3-1. 재고 증가 (정상) - ID=1인 도서의 재고를 5개 증가
PATCH http://localhost:8080/api/v1/books/1/stock/increase?quantity=5

### 3-2. 재고 감소 (정상) - ID=1인 도서의 재고를 3개 감소
PATCH http://localhost:8080/api/v1/books/1/stock/decrease?quantity=3

###############################################################################
# 4. 도서 정보 수정 테스트 (정상 케이스)
###############################################################################

### 4-1. 도서 정보 수정 (정상) - ID=1인 도서의 정보 수정
PUT http://localhost:8080/api/v1/books/1
Content-Type: application/json

{
  "title": "스프링 부트와 AWS로 혼자 구현하는 웹 서비스 (개정판)",
  "author": "이동욱",
  "publisher": "프리렉",
  "publishDate": "2019-12-24"
}

###############################################################################
# 5. 예외 처리 테스트 - BookNotFoundException (404 에러)
###############################################################################

### 5-1. 존재하지 않는 도서 ID로 조회 - BookNotFoundException 발생
GET http://localhost:8080/api/v1/books/999

### 5-2. 존재하지 않는 ISBN으로 조회 - BookNotFoundException 발생
GET http://localhost:8080/api/v1/books/isbn/1234567890123

### 5-3. 존재하지 않는 도서 ID로 재고 증가 시도 - BookNotFoundException 발생
PATCH http://localhost:8080/api/v1/books/999/stock/increase?quantity=5

### 5-4. 존재하지 않는 도서 ID로 정보 수정 시도 - BookNotFoundException 발생
PUT http://localhost:8080/api/v1/books/999
Content-Type: application/json

{
  "title": "존재하지 않는 도서",
  "author": "테스트",
  "publisher": "테스트",
  "publishDate": "2023-01-01"
}

### 5-5. 존재하지 않는 도서 ID로 삭제 시도 - BookNotFoundException 발생
DELETE http://localhost:8080/api/v1/books/999

###############################################################################
# 6. 예외 처리 테스트 - DuplicateIsbnException (409 에러)
###############################################################################

### 6-1. 중복 ISBN으로 도서 등록 시도 - DuplicateIsbnException 발생
# 위에서 이미 등록한 ISBN을 다시 등록하려고 시도
POST http://localhost:8080/api/v1/books
Content-Type: application/json

{
  "isbn": "9788966262281",
  "title": "중복 ISBN 테스트 도서",
  "author": "테스트 저자",
  "publisher": "테스트 출판사",
  "publishDate": "2023-01-01",
  "stockQuantity": 1
}

###############################################################################
# 7. 예외 처리 테스트 - InsufficientStockException (400 에러)
###############################################################################

### 7-1. 먼저 재고가 적은 도서의 현재 상태 확인
GET http://localhost:8080/api/v1/books/3

### 7-2. 재고보다 많은 수량 감소 시도 - InsufficientStockException 발생
# ID=3인 도서의 재고가 3개인데 10개를 감소시키려고 시도
PATCH http://localhost:8080/api/v1/books/3/stock/decrease?quantity=10

### 7-3. 재고를 모두 소진시킨 후 추가 감소 시도
# 먼저 재고를 모두 소진
PATCH http://localhost:8080/api/v1/books/3/stock/decrease?quantity=3

# 재고가 0인 상태에서 추가 감소 시도 - InsufficientStockException 발생
PATCH http://localhost:8080/api/v1/books/3/stock/decrease?quantity=1

###############################################################################
# 8. 예외 처리 테스트 - IllegalArgumentException (400 에러)
###############################################################################

### 8-1. 음수 재고 증가 시도 - IllegalArgumentException 발생 가능
PATCH http://localhost:8080/api/v1/books/1/stock/increase?quantity=-5

### 8-2. 음수 재고 감소 시도 - IllegalArgumentException 발생 가능
PATCH http://localhost:8080/api/v1/books/1/stock/decrease?quantity=-3

###############################################################################
# 9. 예외 처리 테스트 - 잘못된 요청 형식 (400 에러)
###############################################################################

### 9-1. 잘못된 JSON 형식으로 도서 등록 시도
POST http://localhost:8080/api/v1/books
Content-Type: application/json

{
  "isbn": "9788960773418",
  "title": "테스트 도서",
  "author": "테스트 저자",
  "publisher": "테스트 출판사",
  "publishDate": "잘못된 날짜 형식",
  "stockQuantity": "문자열"
}

### 9-2. 필수 필드 누락으로 도서 등록 시도
POST http://localhost:8080/api/v1/books
Content-Type: application/json

{
  "title": "제목만 있는 도서"
}

###############################################################################
# 10. 도서 삭제 테스트 (정상 케이스)
###############################################################################

### 10-1. 도서 삭제 (정상) - ID=2인 도서 삭제
DELETE http://localhost:8080/api/v1/books/2

### 10-2. 삭제 후 조회하여 삭제 확인 - BookNotFoundException 발생해야 함
GET http://localhost:8080/api/v1/books/2

###############################################################################
# 11. 최종 상태 확인
###############################################################################

### 11-1. 최종 도서 목록 확인
GET http://localhost:8080/api/v1/books

###############################################################################
# 테스트 시나리오 요약:
# 
# 정상 케이스:
# - 도서 등록, 조회, 수정, 삭제
# - 재고 증가/감소
# - 다양한 검색 방법
#
# 예외 케이스:
# - BookNotFoundException (404): 존재하지 않는 도서 접근
# - DuplicateIsbnException (409): 중복 ISBN 등록
# - InsufficientStockException (400): 재고 부족
# - IllegalArgumentException (400): 잘못된 인수
# - 잘못된 요청 형식 (400): JSON 파싱 오류, 필수 필드 누락
#
# 각 예외는 GlobalExceptionHandler에서 일관된 형태로 처리되어
# 적절한 HTTP 상태 코드와 오류 정보를 반환한다.
###############################################################################
